# ---- Supabase (App Travluin data + auth foundation) ----
# Copy this file to `.env.local` and fill in the values from your Supabase project
# (Project Settings → API). NEVER commit real keys.

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe for the browser; row-level security enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — used ONLY by local tooling to run the seed against a remote
# project (never referenced by app code, never sent to the browser). Optional.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Travel providers (optional; default to the built-in mock adapters) ----
# Set to "amadeus" AND provide credentials to switch off the mock. Without
# credentials the app keeps using the mock so nothing breaks.
HOTEL_PROVIDER=mock
FLIGHT_PROVIDER=mock
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ---- Currency rates (optional) ----
# exchangerate.host-compatible endpoint (base=SAR). If unset, a maintained
# fallback rates table is used so the converter always works.
RATES_API_URL=

# ---- Hotel supplier credential vault (REQUIRED for supplier settings) ----
# 32-byte key, base64. Encrypts supplier credentials at rest (AES-256-GCM) so
# plaintext secrets are never stored. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this key makes previously-stored credentials undecryptable (re-enter them).
SETTINGS_ENCRYPTION_KEY=

# ---- TBO hotel API (optional; machine-to-machine XML/API, NO OTP) ----
# Credentials are entered/encrypted via Settings → "ربط مزوّدي الفنادق", NOT here.
# Set TBO_LIVE=1 only when a real TBO endpoint is reachable; otherwise the adapter
# simulates auth + search against stored credentials (no live network call).
TBO_LIVE=

# Teletel (Chatwoot-compatible) customer platform — server-only, optional.
TELETEL_BASE_URL=
TELETEL_API_TOKEN=
TELETEL_ACCOUNT_ID=1
