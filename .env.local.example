# ─────────────────────────────────────────────────────────────────────────────
# PalmX (.env.local.example)
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Obtain from @BotFather on Telegram
# ⚠️  REGENERATE IMMEDIATELY if this token is ever exposed in chat / logs.
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Random 32-character string used to validate incoming webhook requests.
# Generate with: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=your-random-32-char-secret-here

# ─── Bot Configuration ────────────────────────────────────────────────────────
# Profit-fee percentage charged to users (5 – 10).  Default: 7
BOT_FEE_PERCENT=7

# Maximum trade size in USD per individual order
BOT_MAX_TRADE_SIZE_USD=1000

# Treasury wallet address on Solana (receives collected fees)
BOT_TREASURY_WALLET=YOUR_SOLANA_TREASURY_WALLET_ADDRESS

# ─── Admin API ────────────────────────────────────────────────────────────────
# Secret for /api/telegram/register-webhook and /api/telegram/bot-control
# Generate with: openssl rand -hex 24
ADMIN_API_SECRET=your-admin-api-secret-here

# ─── Solana / Jupiter ─────────────────────────────────────────────────────────
# Jupiter Aggregator v6 base URL (default is public; use private for rate limits)
JUPITER_API_BASE_URL=https://quote-api.jup.ag

# Solana RPC endpoint (Mainnet-Beta)
# Free options: https://api.mainnet-beta.solana.com
# Paid options: Helius, QuickNode, Alchemy (recommended for production)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Wallet Connect (Phantom deep-link) ──────────────────────────────────────
# Public key of a throwaway Solana keypair used for Phantom encryption handshake.
# Generate with: solana-keygen new --no-bip39-passphrase
PHANTOM_DAPP_ENCRYPTION_PUBLIC_KEY=YOUR_PHANTOM_DAPP_PUBLIC_KEY

# ─── Notes ────────────────────────────────────────────────────────────────────
# • The bot is NON-CUSTODIAL: private keys are NEVER stored.
# • Wallet connect uses Phantom / Solflare deep-link protocol only.
# • BOT_TREASURY_WALLET receives on-chain fee transfers initiated by end-users.
